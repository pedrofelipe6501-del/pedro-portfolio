</div>

<script>
  // Botão voltar ao topo com comportamento suave
  const backBtn = document.getElementById('backToTop');
  if(backBtn) {
    backBtn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }
  // Mostrar botão após scroll
  window.addEventListener('scroll', () => {
    if(window.scrollY > 400) {
      backBtn.style.opacity = '1';
      backBtn.style.visibility = 'visible';
      backBtn.style.transform = 'scale(1)';
    } else {
      backBtn.style.opacity = '0.6';
      backBtn.style.visibility = 'visible';
    }
  });
  backBtn.style.transition = 'all 0.2s';
  backBtn.style.opacity = '0.8';
  
  // Adicionar pequeno efeito nos cards para garantir animação (opcional)
  const sections = document.querySelectorAll('section');
  // Se quiser um intersect observer para animar novamente? Mas já aplicamos CSS fade-up, mas para garantir que todos vejam
  // Corrigir delay visual configurando atributos
  sections.forEach((sec, idx) => {
    sec.style.animationDelay = `${0.1 + idx * 0.07}s`;
  });

  // Prevenir quebra de links do whatsapp
  const whatsLink = document.querySelector('.contact-card a[href*="wa.me"]');
  if(whatsLink) {
    whatsLink.addEventListener('click', (e) => {
      // só garante que link é correto
      console.log('whatsApp contato');
    });
  }
  
  // Extra: tooltip sutil em badges? não necessário, mas legado.
</script>
